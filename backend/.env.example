# ============================================================
# Bitshake Backend — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_NAME=bitshake
DB_USER=bitshake
DB_PASSWORD=CHANGE_ME_strong_database_password_here

# ── MQTT (HiveMQ Cloud) ──────────────────────────────────────
# Note: In the HiveMQ dashboard, this is listed as "TLS MQTT URL".
# You MUST keep the "mqtts://" prefix here!
MQTT_HOST=mqtts://your-broker-url.s1.eu.hivemq.cloud:8883
MQTT_USER=your_hivemq_username
MQTT_PASSWORD=your_hivemq_password
MQTT_TOPIC=tele/+/SENSOR

# ── API Server ───────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_random_64_character_string_here
CORS_ORIGIN=https://your-dashboard.vercel.app
PORT=3001

# ── Admin User (used by setup-user.js) ───────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_your_dashboard_login_password

# ── Cloudflare Tunnel ──────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=ey...your_long_token_here

# ── Marstek Solar Integration ──────────────────────────────────
HAME_USER=your_secondary_marstek_account@email.com
HAME_PASS=your_secondary_marstek_password
MARSTEK_MAC=001122334455
